{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@prahari/tokens/*": ["packages/tokens/*"],
      "@prahari/theme/*": ["packages/theme/*"],
      "@prahari/components/*": ["packages/components/*"],
      "@prahari/layouts/*": ["packages/layouts/*"],
      "@prahari/charts/*": ["packages/charts/*"],
      "@prahari/utils/*": ["packages/utils/*"],
      "@prahari/state/*": ["packages/state/*"]
    }
  },
  "include": ["packages", "apps"]
}
