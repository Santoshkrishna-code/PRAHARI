# App Configuration
APP_NAME=prahari-ai-platform
APP_ENV=development
PORT=8000
DEBUG=true

# Security & Authentication
JWT_SECRET_KEY=secure_development_jwt_secret_key_change_in_production_32_bytes
JWT_ALGORITHM=HS256

# Relational Database (PostgreSQL Async)
DATABASE_URL=postgresql+asyncpg://postgres:postgres_secure_pass@localhost:5432/prahari_db

# Distributed Cache (Redis)
REDIS_URL=redis://:redis_secure_pass@localhost:6379/0

# Observability & OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=prahari-ai-platform
ENABLE_TELEMETRY=false

# Logging Config
LOG_LEVEL=INFO
JSON_LOGS=true
