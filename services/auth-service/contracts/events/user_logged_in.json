{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UserLoggedInEvent",
  "type": "object",
  "required": ["event_id", "timestamp", "user_id", "email", "ip_address", "user_agent"],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "user_id": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "ip_address": {
      "type": "string",
      "format": "ipv4"
    },
    "user_agent": {
      "type": "string"
    }
  }
}
