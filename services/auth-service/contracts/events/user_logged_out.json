{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UserLoggedOutEvent",
  "type": "object",
  "required": ["event_id", "timestamp", "user_id", "reason"],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "user_id": {
      "type": "string"
    },
    "reason": {
      "type": "string",
      "enum": ["user_request", "session_timeout", "admin_force"]
    }
  }
}
