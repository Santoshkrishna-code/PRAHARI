{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PasswordResetEvent",
  "type": "object",
  "required": ["event_id", "timestamp", "user_id", "email", "status"],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "user_id": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "status": {
      "type": "string",
      "enum": ["requested", "completed", "failed"]
    }
  }
}
