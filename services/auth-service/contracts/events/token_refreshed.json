{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TokenRefreshedEvent",
  "type": "object",
  "required": ["event_id", "timestamp", "user_id", "expires_in"],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "user_id": {
      "type": "string"
    },
    "expires_in": {
      "type": "integer"
    }
  }
}
