{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UserRegisteredEvent",
  "type": "object",
  "required": ["event_id", "timestamp", "user_id", "email", "role", "first_name", "last_name"],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "user_id": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "role": {
      "type": "string",
      "enum": ["Worker", "SafetySupervisor", "PlantManager"]
    },
    "first_name": {
      "type": "string"
    },
    "last_name": {
      "type": "string"
    }
  }
}
