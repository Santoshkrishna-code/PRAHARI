# ==============================================================================
# PRAHARI Environmental Configuration Example
# Copy this file to .env and configure local secrets.
# ==============================================================================

# Global Configurations
ENV=development # development, staging, production
AWS_REGION=us-east-1
LOG_LEVEL=debug

# AWS Credentials (For local development, use mock credentials or IAM roles)
AWS_ACCESS_KEY_ID=mock_access_key
AWS_SECRET_ACCESS_KEY=mock_secret_key

# PostgreSQL Core Database Config
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres_secure_pass
DB_NAME=prahari_db
DB_SSL_MODE=disable

# TimescaleDB IoT Telemetry DB Config
TIMESERIES_DB_HOST=localhost
TIMESERIES_DB_PORT=5433
TIMESERIES_DB_USER=postgres
TIMESERIES_DB_PASSWORD=timescale_secure_pass
TIMESERIES_DB_NAME=prahari_telemetry

# ElastiCache Redis Cache Config
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_pass

# Apache Kafka / Amazon MSK Config
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=prahari-services
KAFKA_GROUP_ID=prahari-consumers

# Amazon OpenSearch Config
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin_secure_pass
OPENSEARCH_INDEX_PREFIX=prahari

# Neo4j Graph Database Config
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_secure_pass

# Amazon Bedrock AI Config
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Cognito Auth Service Config
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Microservices Port Mappings (Local Development)
GATEWAY_SERVICE_PORT=8000
AUTH_SERVICE_PORT=8001
USER_SERVICE_PORT=8002
PERMIT_SERVICE_PORT=8003
INCIDENT_SERVICE_PORT=8004
EMERGENCY_SERVICE_PORT=8005
COMPLIANCE_SERVICE_PORT=8006
NOTIFICATION_SERVICE_PORT=8007
ANALYTICS_SERVICE_PORT=8008
AI_ORCHESTRATOR_PORT=8009
LOCATION_SERVICE_PORT=8010
DIGITAL_TWIN_SERVICE_PORT=8011

# Computer Vision Configurations
RTSP_STREAM_URLS=rtsp://localhost:8554/cam1,rtsp://localhost:8554/cam2
CV_INFERENCE_CONFIDENCE_THRESHOLD=0.5
YOLO_MODEL_PATH=/opt/prahari/models/yolov8x-safety.onnx
